*.log
logs/

# Arquivos temporários
*.tmp
*.temp

# Arquivos de configuração local
application-local.yml
application-dev.yml

# Arquivos de teste
src/test/

# Git
.git/
.gitignore

# Docker
Dockerfile*
.dockerignore

# Scripts de build (já não são necessários)
build-and-push.sh
